{
  "name": "webchat",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "format": "prettier --write '**/*.{ts,tsx,json,yaml,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,yaml,md}'",
    "spell": "cspell --no-progress '**/*.{ts,tsx}'",
    "start:dev": "docker compose -f docker-compose.dev.yml up -d && pnpm dev",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "cspell --no-progress"
    ],
    "*.{ts,tsx,json,yaml,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "cspell": "^9.7.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
